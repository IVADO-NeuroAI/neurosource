{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dataset Schema",
  "type": "object",
  "required": ["dataset_name", "dataset_id", "modalities", "access_type", "url"],
  "properties": {
    "dataset_name": {
      "type": "string",
      "description": "Full name of the dataset."
    },
    "dataset_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]+$",
      "description": "Unique identifier tag for this dataset (e.g., BNCI2014-001)."
    },
    "modalities": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Data modalities present in the dataset."
    },
    "species": {
      "type": "string",
      "description": "Species of the subjects."
    },
    "recording_task": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tasks performed during recording."
    },
    "access_type": {
      "type": "string",
      "description": "Access level."
    },
    "num_subjects": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of subjects in the dataset."
    },
    "num_sessions": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of recording sessions."
    },
    "year": {
      "type": "integer",
      "minimum": 1980,
      "maximum": 2100
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Primary URL to access the dataset."
    },
    "repository": {
      "type": "string",
      "description": "Data platform hosting this dataset (e.g., OpenNeuro, DANDI)."
    },
    "license": {
      "type": "string",
      "description": "License of the dataset (validated against taxonomies.yaml)."
    },
    "bids_compliant": {
      "type": "boolean"
      },
    "paper_url": {
      "type": "string",
      "format": "uri"
    },
    "paper_doi": {
      "type": "string",
      "description": "DOI of the associated publication."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Freeform tags for search and filtering."
    },
    "clinical_based_sample": {
      "type": "boolean"
      },
    "notes": {
      "type": "string",
      "description": "Freeform notes or context."
    }
  }
}
