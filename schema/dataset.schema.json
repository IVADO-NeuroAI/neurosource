{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Neural Dataset Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["dataset_id", "dataset_name", "modalities", "access_type", "url"],
  "properties": {
    "dataset_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable identifier used by model entries to reference this dataset."
    },
    "dataset_name": {
      "type": "string",
      "minLength": 1,
      "description": "Full dataset name."
    },
    "modalities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "description": "Modalities included in the dataset."
    },
    "year": {
      "type": "integer",
      "minimum": 1980,
      "maximum": 2100
    },
    "species": {
      "type": "string",
      "minLength": 1,
      "description": "Primary species represented in the dataset."
    },
    "recording_task": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Main experimental or benchmark task associated with the dataset."
    },
    "access_type": {
      "type": "string",
      "description": "Access level."
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "paper_url": {
      "type": "string",
      "format": "uri"
    },
    "paper_doi": {
      "type": "string",
      "minLength": 1,
      "description": "DOI of the associated publication."
    },
    "license": {
      "type": "string",
      "minLength": 1,
      "description": "License of the dataset."
    },
    "notes": {
      "type": "string",
      "minLength": 1
    },
    "num_subjects": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of subjects in the dataset."
    },
    "num_sessions": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of recording sessions."
    },
    "repository": {
      "type": "string",
      "description": "Data platform hosting this dataset (e.g., OpenNeuro, DANDI)."
    },
    "bids_compliant": {
      "type": "boolean"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Freeform tags for search and filtering."
    },
    "clinical_based_sample": {
      "type": "boolean"
    },
    "hours": {
      "type": "integer",
      "minimum": 0,
      "description": "Total hours of recording time."
    }
  }
}
